<?xml version="1.0" encoding="UTF-8"?>
<timeSeriesFormatterConfig xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

    <formatter class="org.openda.exchange.timeseries.DelimitedTextTimeSeriesFormatter">
        <dateTimeSelector>0</dateTimeSelector>
        <valueSelector>1</valueSelector>
        <delimiter>,</delimiter>
        <commentMarker>#</commentMarker>
        <skipLines>1</skipLines>
    </formatter>

    <!--
        Daily mean temperature at 0.5 m depth.
        Timestamp = 00:00:00 of the day AFTER the observation window
        (e.g., 2025-01-02T00:00:00 = mean over Jan 1).
        Generated by: scripts/prep_obs.py

        standardDeviation = SIGMA_OBS from main_EnKF.py (0.4 degC).
        id must match the predictorVector id in simstratStochModel.xml.
    -->
    <timeSeries id="depth_0.5.temperature" status="use" standardDeviation="0.4">
        obs_depth_0.5m.csv
    </timeSeries>

</timeSeriesFormatterConfig>
